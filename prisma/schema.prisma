generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  name           String?
  age            Int?
  sex            String?
  profilePhotoUrl String?
  createdAt      DateTime    @default(now())
  checkIns       CheckIn[]
  badges         UserBadge[]
  preferences    UserPreferences?
  dailyLogs      DailyLog[]
  currentMedal   String?     // INICIO | BRONCE | PLATA | ORO | PLATINO | DIAMANTE | LEYENDA
  medalUpdatedAt DateTime?
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  weight     Float
  height     Float
  waist      Float?
  hips       Float?
  chest      Float?
  arms       Float?
  thighs     Float?   // muslos
  calves     Float?   // pantorrillas
  shoulders  Float?   // hombros
  goal       String @default("definicion")

  frontPhotoUrl  String?
  sidePhotoUrl   String?
  photoExpiresAt DateTime?

  age           Int?
  sex           String?
  activityLevel String?

  bodyScore         Int?
  rank              String?
  analysis          String?
  dietPlan          String?
  customizationUsed Boolean  @default(false)

  @@index([userId])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])

  // Entrenamiento
  trainingDays      Int?           // días preferidos por semana
  cardioTime        String?        // "mañana" | "tarde" | "noche" | "separado" | "ninguno"
  equipment         String?        // "gym" | "casa" | "mixto"
  likedExercises    String?        // JSON: string[]
  dislikedExercises String?        // JSON: string[]
  trainingNotes     String?        // notas libres

  // Dieta
  dietNotes         String?        // alergias, preferencias, intolerancias
  freeTextContext   String?        // contexto libre del usuario

  // Datos físicos editables (override del check-in)
  height            Float?
  activityLevel     String?

  // Notificaciones
  weeklyEmailEnabled Boolean @default(true)

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badge    String
  earnedAt DateTime @default(now())

  @@unique([userId, badge])
}

model DailyLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime // normalizado a medianoche UTC del día
  createdAt DateTime @default(now())

  // Cuestionario rápido (sliders / booleans)
  dietScore    Int      // 0-100: % cumplimiento dieta
  trainedToday Boolean  // ¿Fuiste al gym/entrenaste?
  sleptWell    Boolean  // ¿Dormiste bien?
  waterOk      Boolean  // ¿Bebiste suficiente agua?
  stressLevel  Int      // 1-5: nivel de estrés
  notes        String?  // texto libre opcional

  // Puntuación de disciplina calculada (0-100, puede ser null hasta que la IA la evalúe)
  disciplineScore Int?

  @@unique([userId, date])
  @@index([userId])
}
