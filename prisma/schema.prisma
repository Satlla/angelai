generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  name      String?
  age       Int?
  sex       String?
  createdAt DateTime    @default(now())
  checkIns    CheckIn[]
  badges      UserBadge[]
  preferences UserPreferences?
}

model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  weight Float
  height Float
  waist  Float?
  hips   Float?
  chest  Float?
  arms   Float?
  goal   String @default("definicion")

  frontPhotoUrl  String?
  sidePhotoUrl   String?
  photoExpiresAt DateTime?

  age           Int?
  sex           String?
  activityLevel String?

  bodyScore Int?
  rank      String?
  analysis  String?
  dietPlan  String?

  @@index([userId])
}

model UserPreferences {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id])

  // Entrenamiento
  trainingDays      Int?           // días preferidos por semana
  cardioTime        String?        // "mañana" | "tarde" | "noche" | "separado" | "ninguno"
  equipment         String?        // "gym" | "casa" | "mixto"
  likedExercises    String?        // JSON: string[]
  dislikedExercises String?        // JSON: string[]
  trainingNotes     String?        // notas libres

  // Dieta
  dietNotes         String?        // alergias, preferencias, intolerancias

  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  badge    String
  earnedAt DateTime @default(now())

  @@unique([userId, badge])
}
