generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  name              String?
  createdAt         DateTime           @default(now())
  age               Int?
  sex               String?
  currentMedal      String?
  medalUpdatedAt    DateTime?
  profilePhotoUrl   String?
  checkIns          CheckIn[]
  dailyLogs         DailyLog[]
  badges            UserBadge[]
  preferences       UserPreferences?
  coachMessages     CoachMessage[]
  foodEntries       FoodEntry[]
  pushSubscriptions PushSubscription[]
}

model FoodEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  name      String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  meal      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CoachMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model PendingInvite {
  id            String    @id @default(cuid())
  token         String    @unique @default(cuid())
  inviterUserId String
  inviteeEmail  String    @unique
  usedAt        DateTime?
  createdAt     DateTime  @default(now())
}

model CheckIn {
  id                String    @id @default(cuid())
  userId            String
  createdAt         DateTime  @default(now())
  weight            Float
  height            Float
  waist             Float?
  hips              Float?
  chest             Float?
  arms              Float?
  bicepFlexed       Float?
  goal              String    @default("definicion")
  frontPhotoUrl     String?
  sidePhotoUrl      String?
  photoExpiresAt    DateTime?
  bodyScore         Int?
  rank              String?
  analysis          String?
  dietPlan          String?
  activityLevel     String?
  age               Int?
  sex               String?
  customizationUsed Boolean   @default(false)
  calves            Float?
  shoulders         Float?
  thighs            Float?
  user              User      @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserPreferences {
  id                   String   @id @default(cuid())
  userId               String   @unique
  trainingDays         Int?
  cardioTime           String?
  equipment            String?
  likedExercises       String?
  dislikedExercises    String?
  trainingNotes        String?
  dietNotes            String?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
  freeTextContext      String?
  weeklyEmailEnabled   Boolean  @default(true)
  activityLevel        String?
  height               Float?
  dailyReminderEnabled Boolean  @default(true)
  user                 User     @relation(fields: [userId], references: [id])
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badge    String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id])

  @@unique([userId, badge])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String
  metadata  String?
  createdAt DateTime @default(now())
}

model DailyLog {
  id              String   @id @default(cuid())
  userId          String
  date            DateTime
  createdAt       DateTime @default(now())
  dietScore       Int
  trainedToday    Boolean
  sleptWell       Boolean
  waterOk         Boolean
  waterGlasses    Int?
  stressLevel     Int
  notes           String?
  disciplineScore Int?
  isCheatDay      Boolean  @default(false)
  isRestDay       Boolean  @default(false)
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId])
}
