# Base de datos (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Anthropic / Claude
ANTHROPIC_API_KEY="sk-ant-..."

# Auth JWT — usa un string aleatorio largo (openssl rand -base64 32)
JWT_SECRET="tu_jwt_secret_muy_largo_y_aleatorio"

# Emails autorizados (separados por comas)
ALLOWED_EMAILS="tu@email.com,otro@email.com"

# Vercel Blob (para fotos corporales, opcional)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Resend (para emails de recordatorio, opcional)
RESEND_API_KEY="re_..."
FROM_EMAIL="AngelAI <noreply@tudominio.com>"

# Cron (protege el endpoint /api/cron)
CRON_SECRET="tu_cron_secret_largo"

# URL pública de la app
NEXT_PUBLIC_APP_URL="https://tudominio.com"
