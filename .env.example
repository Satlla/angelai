# ─── Base de datos ────────────────────────────────────────────────────────────
# REQUERIDO: PostgreSQL (Neon, Supabase, Railway, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname"
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ─── IA ───────────────────────────────────────────────────────────────────────
# REQUERIDO: API key de Anthropic (https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Autenticación ────────────────────────────────────────────────────────────
# REQUERIDO: Secreto JWT — genera con: openssl rand -hex 32
JWT_SECRET="tu_jwt_secret_muy_largo_y_aleatorio_min_32_chars"

# REQUERIDO: Emails autorizados (separados por comas, sin espacios)
ALLOWED_EMAILS="tu@email.com,otro@email.com"

# ─── Almacenamiento de fotos ──────────────────────────────────────────────────
# OPCIONAL: Vercel Blob (para fotos corporales en check-in)
# Obtener en: Vercel Dashboard → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# OPCIONAL: Resend para emails de recordatorio (https://resend.com)
RESEND_API_KEY="re_..."
# Dirección verificada en Resend — debe usar dominio propio en producción
FROM_EMAIL="AngelAI <hola@angelai.app>"

# ─── Crons ────────────────────────────────────────────────────────────────────
# REQUERIDO si usas Vercel Crons: genera con: openssl rand -hex 32
# Vercel lo envía automáticamente como: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="tu_cron_secret_largo"

# ─── App ──────────────────────────────────────────────────────────────────────
# URL pública (sin trailing slash)
NEXT_PUBLIC_APP_URL="https://tudominio.com"
